# OpenRouter API Key (Required)
# Get your free key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use via OpenRouter
# Free/cheap options:
#   anthropic/claude-3-haiku        (fast, cheap)
#   anthropic/claude-3.5-sonnet     (smarter, costs more)
#   openai/gpt-4o-mini              (fast, cheap)
#   mistralai/mistral-7b-instruct   (very cheap)
#   meta-llama/llama-3-8b-instruct  (free tier available)
OPENROUTER_MODEL=anthropic/claude-3-haiku

# OpenWeatherMap API Key (Required)
# Get free key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# NewsAPI Key (Required)
# Get free key from: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# GitHub Token (Optional — increases rate limits)
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Cache settings
CACHE_TTL_SECONDS=300

# Log level
LOG_LEVEL=INFO
